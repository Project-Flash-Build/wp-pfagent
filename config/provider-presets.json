{
  "schemaVersion": 1,
  "families": {
    "openai-compatible": {
      "label": "OpenAI compatible",
      "auth": "bearer",
      "defaultHeaders": {
        "Authorization": "Bearer {{api_key}}",
        "Content-Type": "application/json"
      },
      "endpoints": {
        "models": "/models",
        "chatCompletions": "/chat/completions",
        "responses": "/responses",
        "embeddings": "/embeddings"
      },
      "discovery": [
        { "path": "/models", "shape": "openai_models_list" }
      ],
      "versions": ["v1"]
    },
    "anthropic-compatible": {
      "label": "Anthropic compatible",
      "auth": "x-api-key",
      "defaultHeaders": {
        "x-api-key": "{{api_key}}",
        "anthropic-version": "{{anthropic_version}}",
        "Content-Type": "application/json"
      },
      "defaults": {
        "anthropic_version": "2023-06-01"
      },
      "endpoints": {
        "messages": "/messages",
        "models": "/models"
      },
      "discovery": [
        { "path": "/models", "shape": "anthropic_models_list" }
      ],
      "versions": ["v1"]
    },
    "gemini-compatible": {
      "label": "Gemini native compatible",
      "auth": "x-goog-api-key",
      "defaultHeaders": {
        "x-goog-api-key": "{{api_key}}",
        "Content-Type": "application/json"
      },
      "endpoints": {
        "models": "/models",
        "generateContent": "/models/{{model}}:generateContent",
        "streamGenerateContent": "/models/{{model}}:streamGenerateContent",
        "embedContent": "/models/{{model}}:embedContent"
      },
      "discovery": [
        { "path": "/models", "shape": "gemini_models_list" }
      ],
      "versions": ["v1beta", "v1"]
    }
  },
  "presets": {
    "openai": {
      "label": "OpenAI",
      "family": "openai-compatible",
      "baseUrl": "https://api.openai.com/v1",
      "modelDiscovery": "api",
      "modelHints": [],
      "status": "direct_api"
    },
    "anthropic": {
      "label": "Anthropic Claude",
      "family": "anthropic-compatible",
      "baseUrl": "https://api.anthropic.com/v1",
