{
  "name": "@projectflash/wp-pfagent",
  "version": "0.1.0",
  "private": true,
  "description": "Agent console for Setyenv WordPress products.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && npm run validate:capabilities && npm run test:dependency && npm run test:api-client && npm run test:agent-api && npm run test:providers && npm run test:agent-tools && vite build",
    "typecheck": "tsc --noEmit",
    "validate:capabilities": "node scripts/validate-capabilities.mjs",
    "test:dependency": "node scripts/test-workflow-dependency.mjs",
    "test:api-client": "node scripts/test-workflow-api-client.mjs",
    "test:agent-api": "node scripts/test-agent-api-client.mjs",
    "test:providers": "node scripts/test-provider-presets.mjs",
    "test:agent-tools": "node scripts/test-agent-tool-contracts.mjs",
    "test:ui": "node scripts/test-ui-sprint-4-5.cjs",
    "test:provider-ui": "node scripts/test-provider-settings-ui.cjs",
    "test:ui-sprint-16": "node scripts/test-ui-sprint-16.cjs",
    "test:beta-walkthrough": "node scripts/test-beta-walkthrough.cjs",
    "test:e2e": "playwright test --config=playwright.config.cjs",
    "test:e2e:ui": "playwright test --config=playwright.config.cjs --headed",
    "test:e2e:wizard": "playwright test --config=playwright.config.cjs tests-e2e/wizard.spec.cjs",
    "test:e2e:chat": "playwright test --config=playwright.config.cjs tests-e2e/chat-basic.spec.cjs",
    "test:e2e:confirmation": "playwright test --config=playwright.config.cjs tests-e2e/chat-confirmation.spec.cjs",
    "test:e2e:multiturn": "playwright test --config=playwright.config.cjs tests-e2e/chat-multiturn.spec.cjs",
    "test:e2e:errors": "playwright test --config=playwright.config.cjs tests-e2e/errors.spec.cjs",
    "test:e2e:sessions": "playwright test --config=playwright.config.cjs tests-e2e/sessions.spec.cjs",
    "test:e2e:visual": "playwright test --config=playwright.config.cjs tests-e2e/visual.spec.cjs",
    "test:e2e:navigation": "playwright test --config=playwright.config.cjs tests-e2e/chat-navigation.spec.cjs",
    "test:e2e:iframe": "playwright test --config=playwright.config.cjs tests-e2e/iframe-orchestrator.spec.cjs",
    "release:package": "node scripts/build-release.mjs",
    "test:release-package": "node scripts/test-release-package.mjs",
    "smoke:release-package:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-release-package-smoke.php",
    "smoke:beta-readiness:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-beta-readiness-smoke.php",
    "test": "npm run validate:capabilities && npm run test:dependency && npm run test:api-client && npm run test:agent-api && npm run test:providers && npm run test:agent-tools",
    "smoke:dependency:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-workflow-dependency-smoke.php",
    "smoke:workflow-api:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-workflow-api-smoke.php",
    "smoke:providers:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-provider-credentials-smoke.php",
    "smoke:model-discovery:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-provider-model-discovery-smoke.php",
    "smoke:provider-health:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-provider-health-smoke.php",
    "smoke:llm-gateway:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-llm-gateway-smoke.php",
    "smoke:llm-stream:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-llm-stream-smoke.php",
    "smoke:agent-runtime:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-agent-minimal-smoke.php",
    "smoke:agent-tooling:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-agent-tooling-smoke.php",
    "smoke:agent-support:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-agent-support-smoke.php",
    "smoke:provider-generation:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-provider-generation-smoke.php",
    "smoke:agent-contract:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-agent-contract-smoke.php",
    "smoke:provider-generation-real:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-provider-generation-real.php",
    "smoke:provider-tool-call-real:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-provider-tool-call-real.php",
    "smoke:action-inspector:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-action-inspector-smoke.php",
    "smoke:security-negative:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-security-negative-smoke.php",
    "smoke:chat-sessions:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-chat-sessions-smoke.php",
    "smoke:observability:docker": "docker exec wp-pfworkflow-wordpress-1 php -d memory_limit=512M /var/www/html/wp-content/plugins/wp-pfagent/tests/runtime-observability-smoke.php",
    "smoke:all:docker": "node scripts/smoke-all.mjs"
  },
  "dependencies": {
    "@wordpress/i18n": "^6.19.0",
    "lucide-react": "^1.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rete": "^2.0.6",
    "rete-area-plugin": "^2.1.5",
    "rete-connection-plugin": "^2.0.5",
    "rete-context-menu-plugin": "^2.0.6",
    "rete-react-plugin": "^2.1.0",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.1",
    "gpt-tokenizer": "^3.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">=20.19"
  }
}
